{
  "name": "build-graph",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "db:migrate": "node scripts/migrate-postgres.mjs && node scripts/migrate-clickhouse.mjs",
    "db:migrate:local": "node --env-file=.env.local scripts/migrate-postgres.mjs && node --env-file=.env.local scripts/migrate-clickhouse.mjs",
    "db:reset": "node scripts/reset-postgres.mjs && node scripts/reset-clickhouse.mjs",
    "db:reset:local": "node --env-file=.env.local scripts/reset-postgres.mjs && node --env-file=.env.local scripts/reset-clickhouse.mjs"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.0",
    "@clickhouse/client": "^1.12.1",
    "@neondatabase/serverless": "^1.0.2",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@trigger.dev/react-hooks": "^4.3.1",
    "@trigger.dev/sdk": "^4.3.1",
    "@xyflow/react": "^12.9.3",
    "ai": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.44.7",
    "lucide-react": "^1.25.0",
    "nanoid": "^6.0.0",
    "next": "16.2.10",
    "postgres": "^3.4.9",
    "radix-ui": "^1.6.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "recharts": "^3.7.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.13.1",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.2.10",
    "jsdom": "^27.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
